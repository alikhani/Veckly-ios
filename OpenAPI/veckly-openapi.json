            "type": "integer",
            "nullable": true,
            "minimum": 1
          },
          "cookTimeMinutes": {
            "type": "integer",
            "nullable": true,
            "minimum": 1
          },
          "cuisine": {
            "type": "string",
            "nullable": true
          },
          "proteinSource": {
            "type": "string",
            "nullable": true
          },
          "mealWeight": {
            "type": "string",
            "nullable": true
          },
          "sourceUrl": {
            "type": "string",
            "nullable": true,
            "format": "uri"
          },
          "source": {
            "type": "string",
            "enum": [
              "user_created",
              "url_import",
              "ai_generated"
            ],
            "default": "user_created"
          },
          "isPublic": {
            "type": "boolean",
            "default": false
