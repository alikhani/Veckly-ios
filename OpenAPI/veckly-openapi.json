          "expiresAt": {
            "type": "string"
          }
        },
        "required": [
          "householdName",
          "status",
          "expiresAt"
        ]
      },
      "CausedBy": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "user"
                ]
              },
              "userId": {
                "type": "string",
                "format": "uuid"
              }
            },
            "required": [
              "source",
              "userId"
            ]
          },
          {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "algorithm"
                ]
              },
              "algorithmVersion": {
                "type": "string"
              },
              "triggeredByUserId": {
                "type": "string",
                "format": "uuid"
              }
            },
            "required": [
              "source",
              "algorithmVersion",
              "triggeredByUserId"
            ]
          },
          {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "enum": [
                  "system"
                ]
              },
              "reason": {
                "type": "string"
              }
            },
            "required": [
              "source",
              "reason"
            ]
          }
        ]
      },
      "WeekPlanEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "householdId": {
            "type": "string",
            "format": "uuid"
          },
