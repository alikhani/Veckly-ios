            "nullable": true,
            "minimum": 1
          },
          "cuisine": {
            "type": "string",
            "nullable": true
          },
          "proteinSource": {
            "type": "string",
            "nullable": true
          },
          "mealWeight": {
            "type": "string",
            "nullable": true
          },
