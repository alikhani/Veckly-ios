            "type": "object",
            "properties": {
              "causedBy": {
                "$ref": "#/components/schemas/CausedBy"
              }
            },
            "required": [
              "causedBy"
            ]
          },
          {
            "oneOf": [
              {
                "type": "object",
                "properties": {
                  "eventType": {
                    "type": "string",
                    "enum": [
                      "week_started"
                    ]
                  }
                },
                "required": [
                  "eventType"
                ]
              },
              {
                "type": "object",
                "properties": {
