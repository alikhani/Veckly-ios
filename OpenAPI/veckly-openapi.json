            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "default": ""
          },
          "servings": {
            "type": "integer",
            "minimum": 1,
            "default": 4
          },
          "ingredients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecipeIngredient"
            },
            "default": []
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecipeStep"
            },
            "default": []
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
