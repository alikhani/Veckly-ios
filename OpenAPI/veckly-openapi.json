{
  "openapi": "3.1.0",
  "info": {
    "title": "Veckly API",
    "version": "0.0.1"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Supabase access token"
      }
    },
    "schemas": {
      "Household": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "member"
            ]
          }
        },
        "required": [
          "id",
          "name",
          "role"
        ]
      },
      "MyHouseholdsResponse": {
        "type": "object",
        "properties": {
          "households": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Household"
            }
          }
        },
        "required": [
          "households"
        ]
      },
      "RenameHouseholdResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ]
      },
      "HouseholdInvite": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "householdId": {
            "type": "string",
            "format": "uuid"
          },
          "token": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "nullable": true,
            "format": "email"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "accepted",
              "revoked",
              "expired"
            ]
          },
          "expiresAt": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "householdId",
          "token",
          "email",
          "status",
          "expiresAt",
          "createdAt"
        ]
      },
      "CreateHouseholdInviteRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "HouseholdInviteListResponse": {
        "type": "object",
        "properties": {
          "invites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HouseholdInvite"
            }
          }
        },
        "required": [
          "invites"
        ]
      },
      "HouseholdInviteLanding": {
        "type": "object",
        "properties": {
          "householdName": {
            "type": "string"
          },
