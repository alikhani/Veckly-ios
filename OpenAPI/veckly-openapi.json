            "type": "string"
          },
          "servings": {
            "type": "integer",
            "minimum": 1
          },
          "ingredients": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecipeIngredient"
            }
          },
          "steps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RecipeStep"
            }
          },
